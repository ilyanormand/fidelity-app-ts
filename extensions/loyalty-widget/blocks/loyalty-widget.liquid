{% assign excluded_tag = block.settings.excluded_tag | strip | downcase %}
{% assign customer_has_excluded_tag = false %}
{% if excluded_tag != "" and customer %}
  {% for tag in customer.tags %}
    {% assign tag_lower = tag | downcase %}
    {% if tag_lower == excluded_tag %}
      {% assign customer_has_excluded_tag = true %}
    {% endif %}
  {% endfor %}
{% endif %}

{% unless customer_has_excluded_tag %}
<div id="loyalty-spa-root" 
  class="{% if customer %}customer-logged-in{% else %}customer-not-logged-in{% endif %}"
  data-customer-id="{% if customer %}{{ customer.id }}{% endif %}"
  {% if block.settings.background_image %}
  style="
    background-image: url('{{ block.settings.background_image | image_url }}');
    {% if block.settings.background_size == 'custom' %}
      background-size: {{ block.settings.background_size_custom }}%;
    {% else %}
      background-size: {{ block.settings.background_size }};
    {% endif %}
    background-position: {{ block.settings.background_position_x }}px {{ block.settings.background_position_y }}px;
    {% if block.settings.background_repeat %}
      background-repeat: repeat;
    {% else %}
      background-repeat: no-repeat;
    {% endif %}
  "
  {% endif %}>
  <div class="loyalty-spa-container">

    <div class="loyalty-navbar">
      <div class="loyalty-navbar-title">
        {% if customer %}
          <p>{{ customer.first_name | default: 'Membre' }}</p>
        {% else %}
          <p>Invité</p>
        {% endif %}
      </div>
      <div class="loyalty-navbar-points">
        <p id="loyalty-navbar-points" class="loyalty-points-display">...</p>
        <p>points</p>
      </div>
      <div class="loyalty-navbar-buttons">
        <button class="fidelity-nav-btn" data-page="my-program-content">
          <img src="{{ 'icon-my-rewards.svg' | asset_url }}" alt="" class="fidelity-nav-icon" width="32" height="32">
          {{ block.settings.nav_my_program }}
        </button>
        <button class="fidelity-nav-btn" data-page="earn-points-content">
          <img src="{{ 'icon-earn-points.svg' | asset_url }}" alt="" class="fidelity-nav-icon" width="32" height="32">
          {{ block.settings.nav_earn_points }}
        </button>
        <button class="fidelity-nav-btn" data-page="change_points-content">
          <img
            src="{{ 'icon-change-points.svg' | asset_url }}"
            alt=""
            class="fidelity-nav-icon"
            width="32"
            height="32"
          >
          {{ block.settings.nav_change_points }}
        </button>
        <button class="fidelity-nav-btn" data-page="my-rewards-content" id="my-rewards-nav-btn" style="display: none;">
          <img src="{{ 'icon-my-program.svg' | asset_url }}" alt="" class="fidelity-nav-icon" width="32" height="32">
          {{ block.settings.nav_my_rewards }}
        </button>
      </div>
    </div>

    {% comment %} Mobile burger menu {% endcomment %}
    <div class="loyalty-navbar-mobile">
      <div class="fidelity-mobile-header">
        <button class="fidelity-burger-btn" id="burger-toggle" aria-label="Toggle menu">
          <span class="fidelity-burger-line"></span>
          <span class="fidelity-burger-line"></span>
          <span class="fidelity-burger-line"></span>
        </button>
        <div class="loyalty-navbar-title">
          {% if customer %}
            <p>{{ customer.first_name | default: block.settings.member_fallback_name }}</p>
          {% else %}
            <p>{{ block.settings.guest_name }}</p>
          {% endif %}
          <span id="loyalty-navbar-points-mobile" class="loyalty-points-display">...</span><span> {{ block.settings.points_label }}</span>
        </div>
      </div>
      <div class="fidelity-mobile-menu" id="mobile-menu">
        <button class="fidelity-nav-btn" data-page="my-program-content">
          <img src="{{ 'icon-my-rewards.svg' | asset_url }}" alt="" class="fidelity-nav-icon" width="32" height="32">
          {{ block.settings.nav_my_program }}
        </button>
        <button class="fidelity-nav-btn" data-page="earn-points-content">
          <img src="{{ 'icon-earn-points.svg' | asset_url }}" alt="" class="fidelity-nav-icon" width="32" height="32">
          {{ block.settings.nav_earn_points }}
        </button>
        <button class="fidelity-nav-btn" data-page="change_points-content">
          <img
            src="{{ 'icon-change-points.svg' | asset_url }}"
            alt=""
            class="fidelity-nav-icon"
            width="32"
            height="32"
          >
          {{ block.settings.nav_change_points }}
        </button>
        <button class="fidelity-nav-btn" data-page="my-rewards-content" id="my-rewards-mobile-btn" style="display: none;">
          <img src="{{ 'icon-my-program.svg' | asset_url }}" alt="" class="fidelity-nav-icon" width="32" height="32">
          {{ block.settings.nav_my_rewards }}
        </button>
      </div>
    </div>

    <div id="loyalty-page-content">
      <div data="div-content" class="loyalty-page" id="my-program-content" style="display: block;">
        {% render 'my-program-content', block: block %}
      </div>
      <div data="div-content" class="loyalty-page" id="earn-points-content" style="display: none;">
        {% render 'earn-points-content', block: block %}
      </div>
      <div data="div-content" class="loyalty-page" id="change_points-content" style="display: none;">
        {% render 'change-points-content', block: block %}
      </div>
      <div data="div-content" class="loyalty-page" id="my-rewards-content" style="display: none;">
        {% render 'my-rewards-content', block: block %}
      </div>
    </div>
  </div>
</div>
{% endunless %}

{% unless customer_has_excluded_tag %}
<script>
  // Data of user available for make requests to API in all tabs
  window.loyaltyConfig = {
    customerId: '{{ customer.id }}',
    customerEmail: '{{ customer.email }}',
    shop: '{{ shop.permanent_domain }}',
  };

  // Fetch points balance
  (function() {
    const pointsElements = document.querySelectorAll('.loyalty-points-display');
    function setPoints(value) {
      pointsElements.forEach(function(el) { el.textContent = value; });
    }
    if (window.loyaltyConfig.customerId) {
        fetch('/apps/loyalty/customer', {
            headers: {
                'ngrok-skip-browser-warning': 'true'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success && data.customer) {
                setPoints(data.customer.currentBalance || 0);
            } else {
                setPoints(0);
            }
        })
        .catch(err => {
            console.error('Error fetching points:', err);
            setPoints(0);
        });
    } else {
        setPoints(0);
    }
  })();
</script>
<script src="{{ 'loader-my-rewards.js' | asset_url }}" defer></script>
<script src="{{ 'loader-change-points.js' | asset_url }}" defer></script>
<script src="{{ 'loyalty-app.js' | asset_url }}" defer></script>
<script src="{{ 'loader-earn-points.js' | asset_url }}" defer></script>
<script src="{{ 'loader-my-program.js' | asset_url }}" defer></script>

<link href="{{ 'styles-loyalty-app.css' | asset_url }}" rel="stylesheet">
{% endunless %}

{% schema %}
{
  "name": "Loyalty Widget",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "excluded_tag",
      "label": "Hide widget for customers with tag",
      "placeholder": "e.g. wholesale",
      "info": "Customers who have this tag will not see the loyalty widget. Leave empty to show for everyone."
    },
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background Size",
      "options": [
        {
          "value": "cover",
          "label": "Cover (recommended)"
        },
        {
          "value": "contain",
          "label": "Contain"
        },
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "background_size_custom",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "%",
      "label": "Custom Size",
      "default": 100,
      "info": "Only applies when 'Custom' is selected"
    },
    {
      "type": "range",
      "id": "background_position_x",
      "min": -500,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Position X (horizontal)",
      "default": 0
    },
    {
      "type": "range",
      "id": "background_position_y",
      "min": -500,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Position Y (vertical)",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "background_repeat",
      "label": "Repeat Background",
      "default": false
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "nav_my_program",
      "label": "Onglet — Mon programme",
      "default": "Mon programme"
    },
    {
      "type": "text",
      "id": "nav_earn_points",
      "label": "Onglet — Gagner des points",
      "default": "Gagner des points"
    },
    {
      "type": "text",
      "id": "nav_change_points",
      "label": "Onglet — Échanger mes points",
      "default": "Échanger mes points"
    },
    {
      "type": "text",
      "id": "nav_my_rewards",
      "label": "Onglet — Mes récompenses",
      "default": "Mes récompenses"
    },
    {
      "type": "text",
      "id": "guest_name",
      "label": "Nom affiché pour les visiteurs non connectés",
      "default": "Invité"
    },
    {
      "type": "text",
      "id": "member_fallback_name",
      "label": "Nom de repli pour les membres sans prénom",
      "default": "Membre"
    },
    {
      "type": "text",
      "id": "points_label",
      "label": "Libellé des points",
      "default": "points"
    },
    {
      "type": "header",
      "content": "Page — Mon Programme"
    },
    {
      "type": "text",
      "id": "my_program_title",
      "label": "Titre",
      "default": "Mon Programme de Fidélité"
    },
    {
      "type": "text",
      "id": "my_program_feature_1",
      "label": "Caractéristique 1",
      "default": "Gagnez des points à chaque achat ou mission"
    },
    {
      "type": "text",
      "id": "my_program_feature_2",
      "label": "Caractéristique 2",
      "default": "Échangez-les contre des réductions"
    },
    {
      "type": "text",
      "id": "my_program_feature_3",
      "label": "Caractéristique 3",
      "default": "Profitez de vos récompenses"
    },
    {
      "type": "header",
      "content": "Page — Gagner des points"
    },
    {
      "type": "text",
      "id": "earn_points_title",
      "label": "Titre",
      "default": "Comment gagner des points ?"
    },
    {
      "type": "text",
      "id": "earn_points_feature_1",
      "label": "Caractéristique 1",
      "default": "Gagner des points, c'est simple comme bonjour !"
    },
    {
      "type": "text",
      "id": "earn_points_feature_2",
      "label": "Caractéristique 2",
      "default": "Chaque euro dépensé = 1 point gagné automatiquement sur votre compte."
    },
    {
      "type": "text",
      "id": "earn_points_feature_3",
      "label": "Caractéristique 3",
