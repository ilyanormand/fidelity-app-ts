    {
      "type": "header",
      "content": "Page — Échanger mes points"
    },
    {
      "type": "text",
      "id": "change_points_title",
      "label": "Titre",
      "default": "Échanger mes points"
    },
    {
      "type": "textarea",
      "id": "change_points_feature_1",
      "label": "Texte d'introduction 1",
      "default": "Chaque achat vous rapporte des points : transformez-les ensuite en bons d'achat ou réductions exclusives."
    },
    {
      "type": "textarea",
      "id": "change_points_feature_2",
      "label": "Texte d'introduction 2",
      "default": "Choisissez votre récompense, cliquez, et profitez-en dès votre prochaine commande"
    },
    {
      "type": "header",
      "content": "Page — Mes récompenses"
    },
    {
      "type": "text",
      "id": "my_rewards_title",
      "label": "Titre",
      "default": "Mes récompenses"
    },
    {
      "type": "textarea",
      "id": "my_rewards_feature_1",
      "label": "Texte d'introduction",
