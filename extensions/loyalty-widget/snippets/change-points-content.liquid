<link href="{{ 'styles-change-points.css' | asset_url }}" rel="stylesheet">

<div class="change-points-content{% if customer %} customer-logged-in{% endif %}" data-customer-id="{{ customer.id }}">
  <h3 class="change-points-title">{{ block.settings.change_points_title }}</h3>
  <div class="change-points-features">
    <p class="change-points-item">{{ block.settings.change_points_feature_1 }}</p>
    <p class="change-points-item">{{ block.settings.change_points_feature_2 }}🎉</p>
  </div>
  <div class="rewards-container" id="rewards-container">
    <div class="fidelity-reward-card">
      <p>{{ 'loyalty_widget.other.loading_tasks' | t }}</p>
    </div>
  </div>
</div>
