<link href="{{ 'styles-earn-points-content.css' | asset_url }}" rel="stylesheet">

<div class="earn-points-content">
  <h3 class="earn-points-title">⭐ {{ block.settings.earn_points_title }}</h3>
  <div class="earn-points-features">
    <p class="earn-points-item">{{ block.settings.earn_points_feature_1 }}</p>
    <p class="earn-points-item" style="margin-bottom: 10px;">
      👉{{ block.settings.earn_points_feature_2 }}
    </p>
    <p class="earn-points-item">{{ block.settings.earn_points_feature_3 }}</p>
    <p class="earn-points-item">{{ block.settings.earn_points_feature_4 }}</p>
  </div>
  <div class="earn-points-tasks" id="earn-points-tasks">
    <p>{{ 'loyalty_widget.other.loading_tasks' | t }}</p>
  </div>
</div>
